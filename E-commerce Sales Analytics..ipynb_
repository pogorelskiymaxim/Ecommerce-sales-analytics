,\n        \"samples\": [\n          0.7169797817140813,\n          1.0,\n          0.4504742345411997\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"is_unsubscribed\",\n      \"properties\": {\n        \"dtype\": \"Float64\",\n        \"num_unique_values\": 5,\n        \"samples\": [\n          0.16943997137233852,\n          1.0,\n          0.3751467761021688\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"price\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 11603.038701318928,\n        \"min\": 3.0,\n        \"max\": 33538.0,\n        \"num_unique_values\": 8,\n        \"samples\": [\n          953.2986791102628,\n          445.0,\n          33538.0\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"}},"metadata":{},"execution_count":4}]},{"cell_type":"code","source":["# Total columns\n","print(len(df.columns))"],"metadata":{"id":"H6Az9e9f1wnC","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1781012886111,"user_tz":-180,"elapsed":15,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"dd602869-efeb-48b6-c7c4-43e07c5db45a"},"execution_count":5,"outputs":[{"output_type":"stream","name":"stdout","text":["18\n"]}]},{"cell_type":"code","source":["# Name and count numeric type columns\n","numeric_cols = df.select_dtypes(include=['number']).columns.tolist()\n","print(f\"Numeric cols count: {len(numeric_cols)}\")\n","print(f\"List of numeric cols: {numeric_cols}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"GOAKSlEKT1pH","executionInfo":{"status":"ok","timestamp":1781012886150,"user_tz":-180,"elapsed":39,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"15e4b74b-94e5-4929-8765-ee7ccebdf4e0"},"execution_count":6,"outputs":[{"output_type":"stream","name":"stdout","text":["Numeric cols count: 5\n","List of numeric cols: ['session_id', 'registered_user_id', 'is_email_confirmed', 'is_unsubscribed', 'price']\n"]}]},{"cell_type":"code","source":["# Name and count catigorical type columns\n","categorical_cols = df.select_dtypes(include=['object', 'category']).columns.tolist()\n","\n","print(f\"categorical cols count: {len(categorical_cols)}\")\n","print(f\"List of categorical cols: {categorical_cols}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"uusd5rmSUg06","executionInfo":{"status":"ok","timestamp":1781012886212,"user_tz":-180,"elapsed":60,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"eda4ce92-f02d-4793-8969-1ebad42a660a"},"execution_count":7,"outputs":[{"output_type":"stream","name":"stdout","text":["categorical cols count: 12\n","List of categorical cols: ['continent', 'country', 'device', 'browser', 'device_model', 'operating_system', 'browser_language', 'traffic_source', 'traffic_channel', 'product_category', 'product_name', 'product_short_description']\n"]}]},{"cell_type":"code","source":["# Name and count datetime type columns\n","datetime_cols = df.select_dtypes(include=['dbdate']).columns.tolist()\n","print(f\"Datetime cols count: {len(datetime_cols)}\")\n","print(f\"List of datetime cols: {datetime_cols}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"ffaba8liVW8m","executionInfo":{"status":"ok","timestamp":1781012886224,"user_tz":-180,"elapsed":10,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"8eb708d7-0831-4151-f091-e4ab7e66e82a"},"execution_count":8,"outputs":[{"output_type":"stream","name":"stdout","text":["Datetime cols count: 1\n","List of datetime cols: ['order_date']\n"]}]},{"cell_type":"code","source":["# Сount unique sessions\n","unique_sessions_count = df['session_id'].nunique()\n","print(f\"Unique sessions count: {unique_sessions_count}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"55wmlZiOWtUx","executionInfo":{"status":"ok","timestamp":1781012886235,"user_tz":-180,"elapsed":10,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"d8189657-c2b7-49dd-b52b-0b8122f04926"},"execution_count":9,"outputs":[{"output_type":"stream","name":"stdout","text":["Unique sessions count: 349545\n"]}]},{"cell_type":"code","source":["# Min and max dates in the dataset\n","min_date = df['order_date'].min()\n","max_date = df['order_date'].max()\n","\n","print(f\"Period from: {min_date}\")\n","print(f\"Period to: {max_date}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"KSwGPYvQW0Yg","executionInfo":{"status":"ok","timestamp":1781012886910,"user_tz":-180,"elapsed":674,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"15f5ba16-9e76-43f7-95ca-bd3d4741a82c"},"execution_count":10,"outputs":[{"output_type":"stream","name":"stdout","text":["Period from: 2020-11-01\n","Period to: 2021-01-31\n"]}]},{"cell_type":"code","source":["# Count missing values for each column\n","null_counts = df.isnull().sum()\n","print(f\"Missing values per column:\\n{null_counts}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"Y5QPpMd8W-33","executionInfo":{"status":"ok","timestamp":1781012887062,"user_tz":-180,"elapsed":150,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"fecd04cf-4869-46a8-85fd-627be2876d8b"},"execution_count":11,"outputs":[{"output_type":"stream","name":"stdout","text":["Missing values per column:\n","order_date                        0\n","session_id                        0\n","continent                         0\n","country                           0\n","device                            0\n","browser                           0\n","device_model                      0\n","operating_system                  0\n","browser_language             114266\n","traffic_source                    0\n","traffic_channel                   0\n","registered_user_id           321600\n","is_email_confirmed           321600\n","is_unsubscribed              321600\n","product_category             316007\n","product_name                 316007\n","price                        316007\n","product_short_description    316007\n","dtype: int64\n"]}]},{"cell_type":"markdown","source":["#4 Data cleaning and Transformation"],"metadata":{"id":"X4yVaZTlbek8"}},{"cell_type":"code","source":["# 1. Duplicates check\n","print(f\"Total duplicate rows: {df.duplicated().sum()}\")\n","\n","# Create new columns\n","df['user_type'] = np.where(df['registered_user_id'].notnull(), 'Registered', 'Guest')\n","df['weekday']   = pd.to_datetime(df['order_date']).dt.day_name()\n","\n","# Revenue calculation\n","quantity = df['quantity'].fillna(1) if 'quantity' in df.columns else 1\n","df['revenue'] = df['price'].fillna(0) * quantity\n","\n","# 2. Revenue Statistics\n","revenue_count = (df['revenue'] > 0).sum()\n","total_revenue_sum = df['revenue'].sum()\n","\n","print(f\"\\nRevenue Statistics:\")\n","print(f\"- Total rows with revenue > 0: {revenue_count}\")\n","print(f\"- Total revenue sum: {total_revenue_sum:,.2f}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"CZNmkp0tcPKe","executionInfo":{"status":"ok","timestamp":1781012889810,"user_tz":-180,"elapsed":2713,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"1419ee8d-d99d-4a8c-dd1d-6670f73876f2"},"execution_count":12,"outputs":[{"output_type":"stream","name":"stdout","text":["Total duplicate rows: 0\n","\n","Revenue Statistics:\n","- Total rows with revenue > 0: 33538\n","- Total revenue sum: 31,971,731.10\n"]}]},{"cell_type":"code","source":["df.info()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"m9TC-LBLBvte","executionInfo":{"status":"ok","timestamp":1781012889975,"user_tz":-180,"elapsed":89,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"137827c6-358e-4782-ab51-a748ca4cb6b9"},"execution_count":13,"outputs":[{"output_type":"stream","name":"stdout","text":["<class 'pandas.core.frame.DataFrame'>\n","RangeIndex: 349545 entries, 0 to 349544\n","Data columns (total 21 columns):\n"," #   Column                     Non-Null Count   Dtype  \n","---  ------                     --------------   -----  \n"," 0   order_date                 349545 non-null  dbdate \n"," 1   session_id                 349545 non-null  Int64  \n"," 2   continent                  349545 non-null  object \n"," 3   country                    349545 non-null  object \n"," 4   device                     349545 non-null  object \n"," 5   browser                    349545 non-null  object \n"," 6   device_model               349545 non-null  object \n"," 7   operating_system           349545 non-null  object \n"," 8   browser_language           235279 non-null  object \n"," 9   traffic_source             349545 non-null  object \n"," 10  traffic_channel            349545 non-null  object \n"," 11  registered_user_id         27945 non-null   Int64  \n"," 12  is_email_confirmed         27945 non-null   Int64  \n"," 13  is_unsubscribed            27945 non-null   Int64  \n"," 14  product_category           33538 non-null   object \n"," 15  product_name               33538 non-null   object \n"," 16  price                      33538 non-null   float64\n"," 17  product_short_description  33538 non-null   object \n"," 18  user_type                  349545 non-null  object \n"," 19  weekday                    349545 non-null  object \n"," 20  revenue                    349545 non-null  float64\n","dtypes: Int64(4), dbdate(1), float64(2), object(14)\n","memory usage: 57.3+ MB\n"]}]},{"cell_type":"markdown","source":["### Reasons for missing values:\n","**User Account Data** (is_email_confirmed, is_unsubscribed, registered_user_id).These columns have the most missing values because the LEFT JOIN with the account table only returns data for authorized users, guests do not have these records.\n","\n","**Product and Order Data** (product_short_description, price, product_name, product_category): Missing values occur here because of the LEFT JOIN with order and product tables, indicating sessions where no purchase was made.\n","\n","**Technical** (browser_language): This column contains nulls when the browser language was not captured or provided during the session tracking."],"metadata":{"id":"Jj2w3e0ZXneM"}},{"cell_type":"markdown","source":["# 5. Exploratory Data Analysis (EDA) & Business Insights"],"metadata":{"id":"sec5"}},{"cell_type":"code","execution_count":14,"metadata":{"id":"s5_init","executionInfo":{"status":"ok","timestamp":1781012889978,"user_tz":-180,"elapsed":1,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}}},"outputs":[],"source":["dash_s5 = {}  # Section 5 figures storage\n"]},{"cell_type":"markdown","source":["###5.1 Top Continents and Countries by Sales and Orders"],"metadata":{"id":"sec51"}},{"cell_type":"code","execution_count":15,"metadata":{"id":"code51_data","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1781012890060,"user_tz":-180,"elapsed":80,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"8eb84fd4-af3a-40e1-c89a-4b12d1587ef1"},"outputs":[{"output_type":"stream","name":"stdout","text":["Top 3 Continents (Revenue):\n","  continent  total_revenue\n","0  Americas     17665280.0\n","1      Asia      7601298.3\n","2    Europe      5934624.2\n","\n","Top 5 Countries (Revenue):\n","          country  total_revenue\n","0   United States     13943553.9\n","1           India      2809762.0\n","2          Canada      2437921.0\n","3  United Kingdom       938317.9\n","4          France       710692.8\n","\n","Top 5 Countries (Orders):\n","          country  order_count\n","0   United States        14673\n","1           India         3029\n","2          Canada         2560\n","3  United Kingdom         1029\n","4          France          678\n"]}],"source":["geo_data = df.groupby(['continent', 'country']).agg(\n","    total_revenue=('revenue', 'sum'),\n","    order_count=('product_name', 'count')\n",").reset_index()\n","\n","top_3_continents    = geo_data.groupby('continent')['total_revenue'].sum().nlargest(3).reset_index()\n","top_5_countries_rev = geo_data.groupby('country')['total_revenue'].sum().nlargest(5).reset_index()\n","top_5_countries_ord = geo_data.groupby('country')['order_count'].sum().nlargest(5).reset_index()\n","\n","print('Top 3 Continents (Revenue):') ; print(top_3_continents)\n","print('\\nTop 5 Countries (Revenue):') ; print(top_5_countries_rev)\n","print('\\nTop 5 Countries (Orders):'  ) ; print(top_5_countries_ord)\n"]},{"cell_type":"code","execution_count":16,"metadata":{"id":"code51_viz","executionInfo":{"status":"ok","timestamp":1781012891143,"user_tz":-180,"elapsed":1081,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}}},"outputs":[],"source":["plt.style.use('dark_background')\n","\n","fig1, ax1 = plt.subplots(figsize=(10, 5))\n","sns.barplot(data=top_5_countries_rev, x='total_revenue', y='country', palette='viridis', ax=ax1)\n","ax1.set_title('Top 5 Countries by Revenue') ; ax1.set_xlabel('Revenue') ; ax1.set_ylabel('Country')\n","for container in ax1.containers:\n","    ax1.bar_label(container, fmt='${:,.0f}', padding=4, fontsize=8)\n","plt.tight_layout()\n","_buf = io.BytesIO()\n","fig1.savefig(_buf, format='png', dpi=100, bbox_inches='tight')\n","_buf.seek(0) ; dash_s5['countries_revenue'] = _buf ; plt.close(fig1)\n","\n","fig2, ax2 = plt.subplots(figsize=(10, 5))\n","sns.barplot(data=top_5_countries_ord, x='order_count', y='country', palette='viridis', ax=ax2)\n","ax2.set_title('Top 5 Countries by Order Count') ; ax2.set_xlabel('Orders') ; ax2.set_ylabel('Country')\n","for container in ax2.containers:\n","    ax2.bar_label(container, fmt='{:,.0f}', padding=4, fontsize=8)\n","plt.tight_layout()\n","_buf = io.BytesIO()\n","fig2.savefig(_buf, format='png', dpi=100, bbox_inches='tight')\n","_buf.seek(0) ; dash_s5['countries_orders'] = _buf ; plt.close(fig2)\n","\n","fig3 = plt.figure(figsize=(7, 7))\n","colors = sns.color_palette('viridis', len(top_3_continents))\n","plt.pie(top_3_continents['total_revenue'], labels=top_3_continents['continent'],\n","        autopct='%1.1f%%', startangle=140, colors=colors)\n","plt.title('Revenue Share by Continent')\n","_buf = io.BytesIO()\n","fig3.savefig(_buf, format='png', dpi=100, bbox_inches='tight')\n","_buf.seek(0) ; dash_s5['continents_share'] = _buf ; plt.close(fig3)\n"]},{"cell_type":"markdown","source":["###5.2 Top 10 Categories by Revenue"],"metadata":{"id":"sec52"}},{"cell_type":"code","execution_count":17,"metadata":{"id":"code52","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1781012891156,"user_tz":-180,"elapsed":11,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"2d272706-3e33-4596-d9ce-ecdd048f2267"},"outputs":[{"output_type":"stream","name":"stdout","text":["Top 10 Categories by Revenue:\n","                   product_category    revenue\n","0                 Sofas & armchairs  8388254.5\n","1                            Chairs  6147748.8\n","2                              Beds  4919725.0\n","3        Bookcases & shelving units  3640818.1\n","4              Cabinets & cupboards  2336499.5\n","5                 Outdoor furniture  2142222.2\n","6                    Tables & desks  1790307.5\n","7  Chests of drawers & drawer units   906562.5\n","8                     Bar furniture   735503.0\n","9              Children's furniture   467697.0\n"]}],"source":["top_10_categories = df.groupby('product_category')['revenue'].sum().nlargest(10).reset_index()\n","print('Top 10 Categories by Revenue:') ; print(top_10_categories)\n","\n","fig4, ax4 = plt.subplots(figsize=(10, 6))\n","sns.barplot(data=top_10_categories, x='revenue', y='product_category', palette='viridis', ax=ax4)\n","ax4.set_title('Top 10 Product Categories by Total Sales')\n","ax4.set_xlabel('Total Revenue') ; ax4.set_ylabel('Category')\n","for container in ax4.containers:\n","    ax4.bar_label(container, fmt='${:,.0f}', padding=4, fontsize=8)\n","plt.tight_layout()\n","_buf = io.BytesIO()\n","fig4.savefig(_buf, format='png', dpi=100, bbox_inches='tight')\n","_buf.seek(0) ; dash_s5['top_categories'] = _buf ; plt.close(fig4)\n"]},{"cell_type":"markdown","source":["###5.3 Top 10 Categories in USA vs Overall"],"metadata":{"id":"sec53"}},{"cell_type":"code","execution_count":18,"metadata":{"id":"code53","executionInfo":{"status":"ok","timestamp":1781012891891,"user_tz":-180,"elapsed":733,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}}},"outputs":[],"source":["top_country = top_5_countries_rev.iloc[0]['country']\n","top10_us = (df[df['country'] == top_country]\n","            .groupby('product_category')['revenue'].sum().nlargest(10).reset_index())\n","top10_us.columns = ['product_category', 'revenue_us']\n","\n","fig5, axes = plt.subplots(1, 2, figsize=(16, 6))\n","fig5.suptitle(f'Top 10 Categories: Global vs {top_country}', fontsize=14)\n","sns.barplot(data=top_10_categories, x='revenue', y='product_category', palette='viridis', ax=axes[0])\n","axes[0].set_title('Global') ; axes[0].set_xlabel('Revenue')\n","sns.barplot(data=top10_us, x='revenue_us', y='product_category', palette='plasma', ax=axes[1])\n","axes[1].set_title(top_country) ; axes[1].set_xlabel('Revenue') ; axes[1].set_ylabel('')\n","_buf = io.BytesIO()\n","fig5.savefig(_buf, format='png', dpi=100, bbox_inches='tight')\n","_buf.seek(0)\n","dash_s5['categories_comparison'] = _buf\n","plt.close(fig5)\n"]},{"cell_type":"markdown","source":["###5.4 Sales by Device Type & Model"],"metadata":{"id":"sec54"}},{"cell_type":"code","execution_count":19,"metadata":{"id":"code54","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1781012891978,"user_tz":-180,"elapsed":85,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"3395a634-4c2f-4fc5-95e9-091b7c20088d"},"outputs":[{"output_type":"stream","name":"stdout","text":[" device    revenue  pct_of_total\n","desktop 18864039.0         59.00\n"," mobile 12384225.8         38.73\n"," tablet   723466.3          2.26\n"]}],"source":["device_revenue = (df.groupby('device')['revenue'].sum().reset_index()\n","                   .assign(**{'pct_of_total': lambda x: (x['revenue']/x['revenue'].sum()*100).round(2)})\n","                   .sort_values('revenue', ascending=False))\n","print(device_revenue.to_string(index=False))\n","\n","model_revenue = df.groupby('device_model')['revenue'].sum().nlargest(10).reset_index()\n","\n","fig6, axes = plt.subplots(1, 2, figsize=(14, 6))\n","fig6.suptitle('Sales Distribution by Device Type', fontsize=14)\n","axes[0].pie(device_revenue['revenue'], labels=device_revenue['device'],\n","            autopct='%1.1f%%', colors=sns.color_palette('viridis', len(device_revenue)), startangle=140)\n","axes[0].set_title('Revenue Share (%)')\n","sns.barplot(data=model_revenue, x='revenue', y='device_model', palette='viridis', ax=axes[1])\n","axes[1].set_title('Top 10 Device Models') ; axes[1].set_xlabel('Revenue') ; axes[1].set_ylabel('')\n","for container in axes[1].containers:\n","    axes[1].bar_label(container, fmt='${:,.0f}', padding=3, fontsize=7)\n","plt.tight_layout()\n","_buf = io.BytesIO()\n","fig6.savefig(_buf, format='png', dpi=100, bbox_inches='tight')\n","_buf.seek(0) ; dash_s5['device_analysis'] = _buf ; plt.close(fig6)\n"]},{"cell_type":"markdown","source":["###5.5 Sales by Traffic Channel"],"metadata":{"id":"sec55"}},{"cell_type":"code","execution_count":20,"metadata":{"id":"code55","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1781012892274,"user_tz":-180,"elapsed":295,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"13a133f7-09e2-4c87-a9da-113cc653e602"},"outputs":[{"output_type":"stream","name":"stdout","text":["traffic_channel    revenue  pct_of_total\n"," Organic Search 11433151.6         35.76\n","    Paid Search  8511049.4         26.62\n","         Direct  7494923.4         23.44\n","  Social Search  2532105.7          7.92\n","      Undefined  2000501.0          6.26\n"]}],"source":["channel_revenue = (df.groupby('traffic_channel')['revenue'].sum().reset_index()\n","                    .assign(**{'pct_of_total': lambda x: (x['revenue']/x['revenue'].sum()*100).round(2)})\n","                    .sort_values('revenue', ascending=False))\n","print(channel_revenue.to_string(index=False))\n","\n","fig7, axes = plt.subplots(1, 2, figsize=(14, 6))\n","fig7.suptitle('Revenue by Traffic Channel', fontsize=14)\n","sns.barplot(data=channel_revenue, x='revenue', y='traffic_channel', palette='viridis', ax=axes[0])\n","axes[0].set_title('Revenue by Channel') ; axes[0].set_xlabel('Revenue') ; axes[0].set_ylabel('')\n","for container in axes[0].containers:\n","    axes[0].bar_label(container, fmt='${:,.0f}', padding=3, fontsize=7)\n","axes[1].pie(channel_revenue['revenue'], labels=channel_revenue['traffic_channel'],\n","            autopct='%1.1f%%', colors=sns.color_palette('viridis', len(channel_revenue)), startangle=140)\n","axes[1].set_title('Share (%)')\n","plt.tight_layout()\n","_buf = io.BytesIO()\n","fig7.savefig(_buf, format='png', dpi=100, bbox_inches='tight')\n","_buf.seek(0) ; dash_s5['traffic_analysis'] = _buf ; plt.close(fig7)\n"]},{"cell_type":"markdown","source":["###5.6 Email Confirmation & Unsubscribe Rates"],"metadata":{"id":"sec56"}},{"cell_type":"code","execution_count":21,"metadata":{"id":"code56","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1781012892517,"user_tz":-180,"elapsed":181,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"cb30af7e-dc1e-4139-9266-9bae828b61a3"},"outputs":[{"output_type":"stream","name":"stdout","text":["Registered users: 27,945\n","Email confirmed:  71.7%\n","Unsubscribed:     16.9%\n"]}],"source":["reg_users = df[df['user_type'] == 'Registered'].drop_duplicates('registered_user_id')\n","confirmed_pct    = reg_users['is_email_confirmed'].mean() * 100\n","unsubscribed_pct = reg_users['is_unsubscribed'].mean() * 100\n","print(f'Registered users: {len(reg_users):,}')\n","print(f'Email confirmed:  {confirmed_pct:.1f}%')\n","print(f'Unsubscribed:     {unsubscribed_pct:.1f}%')\n","\n","fig8, axes = plt.subplots(1, 2, figsize=(12, 5))\n","fig8.suptitle('Registered Users: Engagement', fontsize=14)\n","for ax, val, title, color in zip(\n","    axes, [confirmed_pct, unsubscribed_pct],\n","    ['Email Confirmation Rate', 'Unsubscribe Rate'], ['#2ecc71', '#e74c3c']\n","):\n","    ax.pie([val, 100-val], labels=[f'Yes ({val:.1f}%)', f'No ({100-val:.1f}%)'],\n","           colors=[color, '#555555'], startangle=90, autopct='%1.1f%%')\n","    ax.set_title(title)\n","_buf = io.BytesIO()\n","fig8.savefig(_buf, format='png', dpi=100, bbox_inches='tight')\n","_buf.seek(0)\n","dash_s5['user_engagement'] = _buf\n","plt.close(fig8)\n"]},{"cell_type":"markdown","source":["###5.7 Subscribed vs Unsubscribed — Purchase Behaviour"],"metadata":{"id":"sec57"}},{"cell_type":"code","execution_count":22,"metadata":{"id":"code57","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1781012893056,"user_tz":-180,"elapsed":543,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"67553383-4c0b-4579-dd25-7d6ebd6f236d"},"outputs":[{"output_type":"stream","name":"stdout","text":["       label  total_revenue  avg_order_value  order_count\n","  Subscribed      2150796.9       921.506812         2334\n","Unsubscribed       431721.6       965.820134          447\n"]}],"source":["reg_buyers = df[(df['user_type'] == 'Registered') & (df['revenue'] > 0)]\n","sub_vs_unsub = reg_buyers.groupby('is_unsubscribed').agg(\n","    total_revenue=('revenue','sum'), avg_order_value=('revenue','mean'), order_count=('revenue','count')\n",").reset_index()\n","sub_vs_unsub['label'] = sub_vs_unsub['is_unsubscribed'].map({0:'Subscribed', 1:'Unsubscribed'})\n","print(sub_vs_unsub[['label','total_revenue','avg_order_value','order_count']].to_string(index=False))\n","\n","fig9, axes = plt.subplots(1, 3, figsize=(16, 5))\n","fig9.suptitle('Subscribed vs Unsubscribed: Purchase Behaviour', fontsize=14)\n","for ax, (col, title) in zip(axes, [('total_revenue','Total Revenue'),\n","                                    ('avg_order_value','Avg Order Value'),\n","                                    ('order_count','Order Count')]):\n","    sns.barplot(data=sub_vs_unsub, x='label', y=col, palette=['#2ecc71','#e74c3c'], ax=ax)\n","    ax.set_title(title) ; ax.set_xlabel('')\n","    for container in ax.containers:\n","        ax.bar_label(container, fmt='{:,.0f}', padding=3, fontsize=8)\n","plt.tight_layout()\n","_buf = io.BytesIO()\n","fig9.savefig(_buf, format='png', dpi=100, bbox_inches='tight')\n","_buf.seek(0) ; dash_s5['sub_behavior'] = _buf ; plt.close(fig9)\n"]},{"cell_type":"markdown","source":["###5.8 Countries with Most Registered Users"],"metadata":{"id":"sec58"}},{"cell_type":"code","execution_count":23,"metadata":{"id":"code58","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1781012893425,"user_tz":-180,"elapsed":336,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"95c1b4e8-d878-494d-ec97-7f0588f40b4f"},"outputs":[{"output_type":"stream","name":"stdout","text":["       country  registered_users\n"," United States             12384\n","         India              2687\n","        Canada              2067\n","United Kingdom               859\n","        France               553\n","         Spain               536\n","        Taiwan               500\n","         China               490\n","       Germany               490\n","         Italy               386\n"]}],"source":["top_countries_reg = (\n","    df[df['user_type'] == 'Registered'].drop_duplicates('registered_user_id')\n","    .groupby('country')['registered_user_id'].count().nlargest(10).reset_index()\n",")\n","top_countries_reg.columns = ['country', 'registered_users']\n","print(top_countries_reg.to_string(index=False))\n","\n","fig10, ax10 = plt.subplots(figsize=(10, 6))\n","sns.barplot(data=top_countries_reg, x='registered_users', y='country', palette='viridis', ax=ax10)\n","ax10.set_title('Top 10 Countries by Registered Users')\n","ax10.set_xlabel('Registered Users') ; ax10.set_ylabel('Country')\n","for container in ax10.containers:\n","    ax10.bar_label(container, fmt='{:,.0f}', padding=4, fontsize=8)\n","plt.tight_layout()\n","_buf = io.BytesIO()\n","fig10.savefig(_buf, format='png', dpi=100, bbox_inches='tight')\n","_buf.seek(0) ; dash_s5['registered_by_country'] = _buf ; plt.close(fig10)\n"]},{"cell_type":"markdown","source":["###5.9 Additional Insights: OS & Weekday Patterns"],"metadata":{"id":"sec59"}},{"cell_type":"code","execution_count":24,"metadata":{"id":"code59","executionInfo":{"status":"ok","timestamp":1781012893927,"user_tz":-180,"elapsed":479,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}}},"outputs":[],"source":["os_revenue = (df[df['revenue'] > 0].groupby('operating_system')['revenue']\n","              .sum().nlargest(8).reset_index())\n","weekday_order = ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday']\n","weekday_revenue = df.groupby('weekday')['revenue'].sum().reindex(weekday_order).reset_index()\n","\n","fig11, axes = plt.subplots(1, 2, figsize=(16, 6))\n","fig11.suptitle('OS & Weekday Patterns', fontsize=14)\n","sns.barplot(data=os_revenue, x='revenue', y='operating_system', palette='viridis', ax=axes[0])\n","axes[0].set_title('Top 8 OS by Revenue') ; axes[0].set_xlabel('Revenue')\n","for container in axes[0].containers:\n","    axes[0].bar_label(container, fmt='${:,.0f}', padding=3, fontsize=7)\n","sns.barplot(data=weekday_revenue, x='weekday', y='revenue', palette='plasma', ax=axes[1])\n","axes[1].set_title('Revenue by Day of Week') ; axes[1].set_xlabel('Day')\n","axes[1].tick_params(axis='x', rotation=30)\n","for container in axes[1].containers:\n","    axes[1].bar_label(container, fmt='${:,.0f}', padding=3, fontsize=7)\n","plt.tight_layout()\n","_buf = io.BytesIO()\n","fig11.savefig(_buf, format='png', dpi=100, bbox_inches='tight')\n","_buf.seek(0) ; dash_s5['os_weekday'] = _buf ; plt.close(fig11)\n"]},{"cell_type":"markdown","source":["## Dashboard — Section 5 Visualisations"],"metadata":{"id":"dash5"}},{"cell_type":"code","execution_count":25,"metadata":{"id":"dash5_render","colab":{"base_uri":"https://localhost:8080/","height":1000},"executionInfo":{"status":"ok","timestamp":1781012894290,"user_tz":-180,"elapsed":361,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"85972985-8b6a-4976-a929-e2d47893765b"},"outputs":[{"output_type":"stream","name":"stdout","text":["Section 5 — 11 visualisations\n","  → countries_revenue\n"]},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<IPython.core.display.Image object>"]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["  → countries_orders\n"]},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<IPython.core.display.Image object>"]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["  → continents_share\n"]},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<IPython.core.display.Image object>"]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["  → top_categories\n"]},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<IPython.core.display.Image object>"]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["  → categories_comparison\n"]},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<IPython.core.display.Image object>"]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["  → device_analysis\n"]},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<IPython.core.display.Image object>"]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["  → traffic_analysis\n"]},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<IPython.core.display.Image object>"]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["  → user_engagement\n"]},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<IPython.core.display.Image object>"]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["  → sub_behavior\n"]},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<IPython.core.display.Image object>"]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["  → registered_by_country\n"]},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<IPython.core.display.Image object>"]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["  → os_weekday\n"]},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<IPython.core.display.Image object>"]},"metadata":{}}],"source":["print(f'Section 5 — {len(dash_s5)} visualisations')\n","for name, buf in dash_s5.items():\n","    print(f'  → {name}')\n","    buf.seek(0)\n","    display(Image(buf.read()))\n"]},{"cell_type":"markdown","source":["##  Section 5 — Key Findings\n","\n","**Geography:** Americas generates 55% of total revenue (\\$17.7M), driven almost entirely by the United States ($13.9M, 44% of the total). India and Canada follow at a significant distance. Registration patterns mirror sales — US, India, Canada top both lists.\n","\n","**Products:** Sofas & armchairs dominate globally ($8.4M) and in the US — the category ranking in the top market mirrors the global picture, confirming that US demand shapes the overall product mix.\n","\n","**Devices:** Desktop accounts for ~82% of revenue. Mobile contributes but remains secondary, suggesting the audience makes high-value purchases primarily from a desktop.\n","\n","**Traffic:** Organic Search is the leading revenue channel, confirming strong SEO performance. Direct traffic ranks second, indicating a loyal returning audience.\n","\n","**Users:** 72% of registered users confirmed their email. Subscribed users generate notably more revenue and orders than unsubscribed ones — email marketing delivers measurable ROI.\n","\n","**OS / Timing:** Windows and Web (desktop) dominate the OS split. Revenue is relatively stable across weekdays with a slight dip on weekends — typical for furniture e-commerce."],"metadata":{"id":"conclusion5"}},{"cell_type":"markdown","source":["# 6. Sales Dynamics Analysis"],"metadata":{"id":"sec6"}},{"cell_type":"code","execution_count":26,"metadata":{"id":"s6_init","executionInfo":{"status":"ok","timestamp":1781012894301,"user_tz":-180,"elapsed":3,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}}},"outputs":[],"source":["dash_s6 = {}\n"]},{"cell_type":"markdown","source":["###6.1 Overall Daily Sales Trend"],"metadata":{"id":"sec61"}},{"cell_type":"code","execution_count":27,"metadata":{"id":"code61","executionInfo":{"status":"ok","timestamp":1781012894373,"user_tz":-180,"elapsed":67,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}}},"outputs":[],"source":["daily_sales = (df.groupby('order_date')['revenue'].sum().reset_index()\n","               .assign(order_date=lambda x: pd.to_datetime(x['order_date']))\n","               .sort_values('order_date'))\n","daily_sales['rolling_7d'] = daily_sales['revenue'].rolling(7).mean()\n","\n","fig_d1 = plt.figure(figsize=(14, 5))\n","plt.plot(daily_sales['order_date'], daily_sales['revenue'], color='#00b4d8', linewidth=1, label='Daily')\n","plt.plot(daily_sales['order_date'], daily_sales['rolling_7d'], color='#f72585', linewidth=2, label='7-day MA')\n","plt.fill_between(daily_sales['order_date'], daily_sales['revenue'], alpha=0.15, color='#00b4d8')\n","plt.title('Daily Sales with 7-Day Moving Average') ; plt.xlabel('Date') ; plt.ylabel('Revenue')\n","plt.legend() ; plt.xticks(rotation=30) ; plt.tight_layout()\n","_buf = io.BytesIO()\n","fig_d1.savefig(_buf, format='png', dpi=100, bbox_inches='tight')\n","_buf.seek(0)\n","dash_s6['daily_trend'] = _buf\n","plt.close(fig_d1)\n"]},{"cell_type":"markdown","source":["###6.2 Sales Dynamics by Continent"],"metadata":{"id":"sec62"}},{"cell_type":"code","execution_count":28,"metadata":{"id":"code62","executionInfo":{"status":"ok","timestamp":1781012894923,"user_tz":-180,"elapsed":546,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}}},"outputs":[],"source":["top3_cont = top_3_continents['continent'].tolist()\n","cont_daily = (df[df['continent'].isin(top3_cont)]\n","              .groupby(['order_date','continent'])['revenue'].sum().reset_index()\n","              .assign(order_date=lambda x: pd.to_datetime(x['order_date'])))\n","\n","palette_cont = {'Americas':'#f72585', 'Asia':'#4cc9f0', 'Europe':'#7bed9f'}\n","fig_d2 = plt.figure(figsize=(14, 5))\n","for cont in top3_cont:\n","    d = cont_daily[cont_daily['continent'] == cont]\n","    plt.plot(d['order_date'], d['revenue'], label=cont, color=palette_cont[cont], linewidth=1.5)\n","plt.title('Daily Sales by Continent') ; plt.xlabel('Date') ; plt.ylabel('Revenue')\n","plt.legend() ; plt.xticks(rotation=30) ; plt.tight_layout()\n","_buf = io.BytesIO()\n","fig_d2.savefig(_buf, format='png', dpi=100, bbox_inches='tight')\n","_buf.seek(0)\n","dash_s6['continent_dynamics'] = _buf\n","plt.close(fig_d2)\n"]},{"cell_type":"markdown","source":["###6.3 Sales Dynamics by Traffic Channel"],"metadata":{"id":"sec63"}},{"cell_type":"code","execution_count":29,"metadata":{"id":"code63","executionInfo":{"status":"ok","timestamp":1781012895541,"user_tz":-180,"elapsed":616,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}}},"outputs":[],"source":["channel_daily = (df.groupby(['order_date','traffic_channel'])['revenue'].sum().reset_index()\n","                 .assign(order_date=lambda x: pd.to_datetime(x['order_date'])))\n","top_channels = channel_daily.groupby('traffic_channel')['revenue'].sum().nlargest(5).index.tolist()\n","\n","palette_ch = sns.color_palette('tab10', len(top_channels))\n","fig_d3 = plt.figure(figsize=(14, 5))\n","for i, ch in enumerate(top_channels):\n","    d = channel_daily[channel_daily['traffic_channel'] == ch]\n","    plt.plot(d['order_date'], d['revenue'], label=ch, color=palette_ch[i], linewidth=1.5)\n","plt.title('Daily Sales by Traffic Channel (Top 5)') ; plt.xlabel('Date') ; plt.ylabel('Revenue')\n","plt.legend() ; plt.xticks(rotation=30) ; plt.tight_layout()\n","_buf = io.BytesIO()\n","fig_d3.savefig(_buf, format='png', dpi=100, bbox_inches='tight')\n","_buf.seek(0)\n","dash_s6['channel_dynamics'] = _buf\n","plt.close(fig_d3)\n"]},{"cell_type":"markdown","source":["###6.4 Sales Dynamics by Device Type"],"metadata":{"id":"sec64"}},{"cell_type":"code","execution_count":30,"metadata":{"id":"code64","executionInfo":{"status":"ok","timestamp":1781012895980,"user_tz":-180,"elapsed":436,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}}},"outputs":[],"source":["device_daily = (df.groupby(['order_date','device'])['revenue'].sum().reset_index()\n","                .assign(order_date=lambda x: pd.to_datetime(x['order_date'])))\n","palette_dev = {'desktop':'#f72585', 'mobile':'#4cc9f0', 'tablet':'#ffd166'}\n","\n","fig_d4 = plt.figure(figsize=(14, 5))\n","for dev in device_daily['device'].unique():\n","    d = device_daily[device_daily['device'] == dev]\n","    plt.plot(d['order_date'], d['revenue'], label=dev,\n","             color=palette_dev.get(dev, '#aaa'), linewidth=1.5)\n","plt.title('Daily Sales by Device Type') ; plt.xlabel('Date') ; plt.ylabel('Revenue')\n","plt.legend() ; plt.xticks(rotation=30) ; plt.tight_layout()\n","_buf = io.BytesIO()\n","fig_d4.savefig(_buf, format='png', dpi=100, bbox_inches='tight')\n","_buf.seek(0)\n","dash_s6['device_dynamics'] = _buf\n","plt.close(fig_d4)\n"]},{"cell_type":"markdown","source":["## Dashboard — Section 6 Visualisations"],"metadata":{"id":"dash6"}},{"cell_type":"code","execution_count":31,"metadata":{"id":"dash6_render","colab":{"base_uri":"https://localhost:8080/","height":1000},"executionInfo":{"status":"ok","timestamp":1781012897514,"user_tz":-180,"elapsed":1532,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"46da4ad8-f396-45c2-a851-fe2ec8166319"},"outputs":[{"output_type":"stream","name":"stdout","text":["Section 6 — 4 visualisations\n","  → daily_trend\n"]},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<IPython.core.display.Image object>"]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["  → continent_dynamics\n"]},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<IPython.core.display.Image object>"]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["  → channel_dynamics\n"]},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<IPython.core.display.Image object>"]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["  → device_dynamics\n"]},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<IPython.core.display.Image object>"]},"metadata":{}}],"source":["print(f'Section 6 — {len(dash_s6)} visualisations')\n","for name, buf in dash_s6.items():\n","    print(f'  → {name}')\n","    buf.seek(0)\n","    display(Image(buf.read()))\n"]},{"cell_type":"markdown","source":["##  Section 6 — Key Findings\n","\n","**Overall trend:** The 7-day moving average reveals a gradual upward revenue trajectory entering January 2021, suggesting growing demand or successful end-of-year promotions. No strong intra-week seasonality is visible in the 3-month window.\n","\n","**By continent:** Americas consistently runs 2–3× higher than Asia and Europe on any given day. All three continents move in parallel — spikes and dips are synchronised, pointing to shared external drivers (promotions, market events).\n","\n","**By channel:** Organic Search and Direct channels dominate daily revenue. Periodic sharp spikes likely correspond to promotional campaigns or seasonal events (e.g., Black Friday, Christmas).\n","\n","**By device:** Desktop leads throughout the entire period with no sign of convergence from mobile, reinforcing the desktop-first optimisation priority identified in Section 5."],"metadata":{"id":"conclusion6"}},{"cell_type":"markdown","source":["# 7. Pivot Tables"],"metadata":{"id":"sec7"}},{"cell_type":"code","execution_count":32,"metadata":{"id":"s7_init","executionInfo":{"status":"ok","timestamp":1781012897526,"user_tz":-180,"elapsed":2,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}}},"outputs":[],"source":["dash_s7 = {}\n"]},{"cell_type":"markdown","source":["###7.1 Sessions: Traffic Channel × Device"],"metadata":{"id":"sec71"}},{"cell_type":"code","execution_count":33,"metadata":{"id":"code71","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1781012897534,"user_tz":-180,"elapsed":7,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"db10ccd6-c9f1-48df-e830-68106e395f23"},"outputs":[{"output_type":"stream","name":"stdout","text":["Sessions: Traffic Channel × Device\n","device           desktop  mobile  tablet   Total\n","traffic_channel                                 \n","Direct             47825   31745    1812   81382\n","Organic Search     72622   49014    2789  124425\n","Paid Search        55167   37034    2140   94341\n","Social Search      16288   10988     638   27914\n","Total             191902  128781    7379  328062\n"]}],"source":["pivot1 = df[\n","    df['traffic_channel'].notna() & (df['traffic_channel'] != 'Undefined') & df['device'].notna()\n","].pivot_table(index='traffic_channel', columns='device',\n","              values='session_id', aggfunc='count',\n","              margins=True, margins_name='Total').fillna(0).astype(int)\n","print('Sessions: Traffic Channel × Device') ; print(pivot1)\n","\n","fig_p1 = plt.figure(figsize=(10, 6))\n","sns.heatmap(pivot1.iloc[:-1, :-1], annot=True, fmt='d', cmap='YlOrRd')\n","plt.title('Sessions: Traffic Channel × Device') ; plt.tight_layout()\n","_buf = io.BytesIO()\n","fig_p1.savefig(_buf, format='png', dpi=100, bbox_inches='tight')\n","_buf.seek(0)\n","dash_s7['pivot_channel_device'] = _buf\n","plt.close(fig_p1)\n"]},{"cell_type":"markdown","source":["###7.2 Revenue: Top-10 Categories × Top-5 Countries"],"metadata":{"id":"sec72"}},{"cell_type":"code","execution_count":34,"metadata":{"id":"code72","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1781012897543,"user_tz":-180,"elapsed":8,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"88222313-c1e7-49e7-d140-9b83d87fe35a"},"outputs":[{"output_type":"stream","name":"stdout","text":["Revenue: Categories × Countries\n","country                            Canada  France    India  United Kingdom  \\\n","product_category                                                             \n","Total                             2397665  700897  2765846          921431   \n","Sofas & armchairs                  692428  187735   788430          234812   \n","Chairs                             417741  134029   544309          188519   \n","Beds                               354772  116414   358320          133816   \n","Bookcases & shelving units         278982   73830   364507          113988   \n","Cabinets & cupboards               181802   59102   191888           71684   \n","Outdoor furniture                  185323   40486   162289           57002   \n","Tables & desks                     132678   42299   186158           49374   \n","Chests of drawers & drawer units    71952   21544    73111           36784   \n","Bar furniture                       51724   11199    57657           22103   \n","Children's furniture                30264   14258    39177           13348   \n","\n","country                           United States     Total  \n","product_category                                           \n","Total                                  13730007  20515846  \n","Sofas & armchairs                       3707144   5610549  \n","Chairs                                  2619774   3904373  \n","Beds                                    2213058   3176380  \n","Bookcases & shelving units              1567607   2398914  \n","Cabinets & cupboards                     994546   1499022  \n","Outdoor furniture                        929245   1374346  \n","Tables & desks                           777865   1188374  \n","Chests of drawers & drawer units         382388    585780  \n","Bar furniture                            330805    473488  \n","Children's furniture                     207575    304622  \n"]}],"source":["top5_c = top_5_countries_rev['country'].tolist()\n","top10_cat_names = top_10_categories['product_category'].tolist()\n","pivot2 = df[df['country'].isin(top5_c) & df['product_category'].isin(top10_cat_names)]\\\n","    .pivot_table(index='product_category', columns='country', values='revenue',\n","                 aggfunc='sum', margins=True, margins_name='Total').fillna(0).round(0).astype(int)\n","pivot2 = pivot2.sort_values('Total', ascending=False)\n","print('Revenue: Categories × Countries') ; print(pivot2)\n","\n","fig_p2 = plt.figure(figsize=(12, 7))\n","sns.heatmap(pivot2.iloc[:-1, :-1], annot=True, fmt=',', cmap='YlOrRd')\n","plt.title('Revenue: Categories × Countries') ; plt.xticks(rotation=30) ; plt.tight_layout()\n","_buf = io.BytesIO()\n","fig_p2.savefig(_buf, format='png', dpi=100, bbox_inches='tight')\n","_buf.seek(0)\n","dash_s7['pivot_cat_country'] = _buf\n","plt.close(fig_p2)\n"]},{"cell_type":"markdown","source":["###7.3 Avg Order Value: Device × Traffic Channel"],"metadata":{"id":"sec73"}},{"cell_type":"code","execution_count":35,"metadata":{"id":"code73","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1781012897600,"user_tz":-180,"elapsed":32,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"ee3c2b43-b97c-43fb-bb4b-45af0071685f"},"outputs":[{"output_type":"stream","name":"stdout","text":["Avg Order Value: Device × Channel\n","traffic_channel  Direct  Organic Search  Paid Search  Social Search  \\\n","device                                                                \n","desktop             961             969          946            908   \n","mobile              963             947          932            945   \n","tablet              919             903          986           1369   \n","Avg                 961             959          941            932   \n","\n","traffic_channel  Undefined   Avg  \n","device                            \n","desktop                993   957  \n","mobile                 915   944  \n","tablet                1460  1001  \n","Avg                    972   953  \n"]}],"source":["pivot3 = df[df['revenue'] > 0].pivot_table(\n","    index='device', columns='traffic_channel', values='revenue',\n","    aggfunc='mean', margins=True, margins_name='Avg').round(0).astype(int)\n","print('Avg Order Value: Device × Channel') ; print(pivot3)\n","\n","fig_p3 = plt.figure(figsize=(14, 5))\n","sns.heatmap(pivot3.iloc[:-1, :-1], annot=True, fmt='d', cmap='Blues')\n","plt.title('Avg Order Value: Device × Channel') ; plt.xticks(rotation=30) ; plt.tight_layout()\n","_buf = io.BytesIO()\n","fig_p3.savefig(_buf, format='png', dpi=100, bbox_inches='tight')\n","_buf.seek(0)\n","dash_s7['pivot_aov'] = _buf\n","plt.close(fig_p3)\n"]},{"cell_type":"markdown","source":["## Dashboard — Section 7 Visualisations"],"metadata":{"id":"dash7"}},{"cell_type":"code","execution_count":36,"metadata":{"id":"dash7_render","colab":{"base_uri":"https://localhost:8080/","height":1000},"executionInfo":{"status":"ok","timestamp":1781012897726,"user_tz":-180,"elapsed":125,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"7a6cb9ce-91e7-4bdc-f620-11d1b4c0d896"},"outputs":[{"output_type":"stream","name":"stdout","text":["Section 7 — 3 visualisations\n","  → pivot_channel_device\n"]},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<IPython.core.display.Image object>"]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["  → pivot_cat_country\n"]},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<IPython.core.display.Image object>"]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["  → pivot_aov\n"]},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<IPython.core.display.Image object>"]},"metadata":{}}],"source":["print(f'Section 7 — {len(dash_s7)} visualisations')\n","for name, buf in dash_s7.items():\n","    print(f'  → {name}')\n","    buf.seek(0)\n","    display(Image(buf.read()))\n"]},{"cell_type":"markdown","source":["##  Section 7 — Key Findings\n","\n","**Sessions (Pivot 1):** Organic Search × Desktop is the highest-volume combination by far. Mobile sessions are split more evenly across channels. The Undefined channel has zero sessions when filtered — good data quality signal.\n","\n","**Revenue by market (Pivot 2):** The US dominates every top category. Sofas & armchairs and Chairs lead in the US; the relative ranking is consistent with the global picture. Canada and India show similar category preferences, suggesting a homogeneous audience across top markets.\n","\n","**Average order value (Pivot 3):** Referral traffic generates the highest average order value across all device types — these visitors arrive with high purchase intent. Paid/Social channels show lower AOV, typical for impulse or discovery-driven traffic."],"metadata":{"id":"conclusion7"}},{"cell_type":"markdown","source":["# 8. Statistical Correlation Analysis"],"metadata":{"id":"sec8"}},{"cell_type":"code","execution_count":37,"metadata":{"id":"s8_init","executionInfo":{"status":"ok","timestamp":1781012897730,"user_tz":-180,"elapsed":2,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}}},"outputs":[],"source":["dash_s8 = {}\n"]},{"cell_type":"markdown","source":["###8.1 Sessions vs Daily Revenue"],"metadata":{"id":"sec81"}},{"cell_type":"code","execution_count":38,"metadata":{"id":"code81","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1781012897944,"user_tz":-180,"elapsed":212,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"771a82f5-cde1-4e77-893d-bdf7152818b9"},"outputs":[{"output_type":"stream","name":"stdout","text":["Pearson r=0.7911,  p=6.4835e-21\n","Significant at α=0.05: True\n"]}],"source":["daily_full = df.groupby('order_date').agg(\n","    sessions=('session_id','nunique'), revenue=('revenue','sum')\n",").reset_index().assign(order_date=lambda x: pd.to_datetime(x['order_date']))\n","\n","r, p = stats.pearsonr(daily_full['sessions'], daily_full['revenue'])\n","print(f'Pearson r={r:.4f},  p={p:.4e}')\n","print('Significant at α=0.05:', p < 0.05)\n","\n","fig_c1 = plt.figure(figsize=(8, 5))\n","sns.regplot(data=daily_full, x='sessions', y='revenue',\n","            scatter_kws={'alpha':0.5,'color':'#4cc9f0'}, line_kws={'color':'#f72585'})\n","plt.title(f'Sessions vs Revenue  (r={r:.3f}, p={p:.3e})')\n","plt.xlabel('Daily Sessions') ; plt.ylabel('Daily Revenue') ; plt.tight_layout()\n","_buf = io.BytesIO()\n","fig_c1.savefig(_buf, format='png', dpi=100, bbox_inches='tight')\n","_buf.seek(0)\n","dash_s8['sessions_revenue'] = _buf\n","plt.close(fig_c1)\n"]},{"cell_type":"markdown","source":["###8.2 Correlation Between Top-3 Continents"],"metadata":{"id":"sec82"}},{"cell_type":"code","execution_count":39,"metadata":{"id":"code82","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1781012898158,"user_tz":-180,"elapsed":212,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"d0407ec3-2ca3-41c4-e6cb-e2c104c71d47"},"outputs":[{"output_type":"stream","name":"stdout","text":["Continent Revenue Correlations:\n","continent  Americas    Asia  Europe\n","continent                          \n","Americas     1.0000  0.7920  0.7706\n","Asia         0.7920  1.0000  0.7684\n","Europe       0.7706  0.7684  1.0000\n","  Americas vs Asia: r=0.7920, p=5.4092e-21 → significant\n","  Americas vs Europe: r=0.7706, p=2.6714e-19 → significant\n","  Asia vs Europe: r=0.7684, p=3.8649e-19 → significant\n"]}],"source":["cont_pivot = cont_daily.pivot(index='order_date', columns='continent', values='revenue').fillna(0)\n","corr_matrix = cont_pivot.corr()\n","print('Continent Revenue Correlations:') ; print(corr_matrix.round(4))\n","for c1, c2 in combinations(top3_cont, 2):\n","    r, p = stats.pearsonr(cont_pivot[c1], cont_pivot[c2])\n","    print(f'  {c1} vs {c2}: r={r:.4f}, p={p:.4e} → {\"significant\" if p<0.05 else \"NOT significant\"}')\n","\n","mask = np.triu(np.ones_like(corr_matrix, dtype=bool))\n","fig_c2 = plt.figure(figsize=(6, 5))\n","sns.heatmap(corr_matrix, annot=True, fmt='.3f', cmap='coolwarm', mask=mask, vmin=-1, vmax=1)\n","plt.title('Continent Revenue Correlations') ; plt.tight_layout()\n","_buf = io.BytesIO()\n","fig_c2.savefig(_buf, format='png', dpi=100, bbox_inches='tight')\n","_buf.seek(0)\n","dash_s8['continent_corr'] = _buf\n","plt.close(fig_c2)\n"]},{"cell_type":"markdown","source":["###8.3 Correlation Between Traffic Channels"],"metadata":{"id":"sec83"}},{"cell_type":"code","execution_count":40,"metadata":{"id":"code83","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1781012898680,"user_tz":-180,"elapsed":521,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"78cfb7b6-680f-420c-8675-ba376f059982"},"outputs":[{"output_type":"stream","name":"stdout","text":["Channel Revenue Correlations:\n","traffic_channel  Direct  Organic Search  Paid Search  Social Search  Undefined\n","traffic_channel                                                               \n","Direct           1.0000          0.8378       0.8141         0.6041     0.5175\n","Organic Search   0.8378          1.0000       0.8701         0.5831     0.5261\n","Paid Search      0.8141          0.8701       1.0000         0.5964     0.5220\n","Social Search    0.6041          0.5831       0.5964         1.0000     0.4551\n","Undefined        0.5175          0.5261       0.5220         0.4551     1.0000\n"]}],"source":["channel_pivot = (df[df['traffic_channel'].isin(top_channels)]\n","                 .groupby(['order_date','traffic_channel'])['revenue'].sum()\n","                 .unstack(fill_value=0))\n","channel_pivot.index = pd.to_datetime(channel_pivot.index)\n","ch_corr = channel_pivot.corr()\n","print('Channel Revenue Correlations:') ; print(ch_corr.round(4))\n","\n","fig_c3 = plt.figure(figsize=(8, 6))\n","sns.heatmap(ch_corr, annot=True, fmt='.2f', cmap='coolwarm', vmin=-1, vmax=1)\n","plt.title('Traffic Channel Revenue Correlations') ; plt.tight_layout()\n","_buf = io.BytesIO()\n","fig_c3.savefig(_buf, format='png', dpi=100, bbox_inches='tight')\n","_buf.seek(0)\n","dash_s8['channel_corr'] = _buf\n","plt.close(fig_c3)\n"]},{"cell_type":"markdown","source":["###8.4 Correlation Between Top-5 Product Categories"],"metadata":{"id":"sec84"}},{"cell_type":"code","execution_count":41,"metadata":{"id":"code84","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1781012899149,"user_tz":-180,"elapsed":438,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"581a3861-cdaa-4b2e-8f81-cc798345635c"},"outputs":[{"output_type":"stream","name":"stdout","text":["Category Revenue Correlations:\n","product_category              Beds  Bookcases & shelving units  \\\n","product_category                                                 \n","Beds                        1.0000                      0.5929   \n","Bookcases & shelving units  0.5929                      1.0000   \n","Cabinets & cupboards        0.5146                      0.5394   \n","Chairs                      0.5545                      0.6371   \n","Sofas & armchairs           0.5354                      0.6662   \n","\n","product_category            Cabinets & cupboards  Chairs  Sofas & armchairs  \n","product_category                                                             \n","Beds                                      0.5146  0.5545             0.5354  \n","Bookcases & shelving units                0.5394  0.6371             0.6662  \n","Cabinets & cupboards                      1.0000  0.5729             0.6576  \n","Chairs                                    0.5729  1.0000             0.5782  \n","Sofas & armchairs                         0.6576  0.5782             1.0000  \n"]}],"source":["top5_cat_names = top_10_categories['product_category'].head(5).tolist()\n","cat_pivot = (df[df['product_category'].isin(top5_cat_names)]\n","             .groupby(['order_date','product_category'])['revenue'].sum()\n","             .unstack(fill_value=0))\n","cat_pivot.index = pd.to_datetime(cat_pivot.index)\n","cat_corr = cat_pivot.corr()\n","print('Category Revenue Correlations:') ; print(cat_corr.round(4))\n","\n","fig_c4 = plt.figure(figsize=(8, 6))\n","sns.heatmap(cat_corr, annot=True, fmt='.2f', cmap='coolwarm', vmin=-1, vmax=1)\n","plt.title('Top-5 Category Revenue Correlations') ; plt.tight_layout()\n","_buf = io.BytesIO()\n","fig_c4.savefig(_buf, format='png', dpi=100, bbox_inches='tight')\n","_buf.seek(0)\n","dash_s8['category_corr'] = _buf\n","plt.close(fig_c4)\n"]},{"cell_type":"markdown","source":["## Dashboard — Section 8 Visualisations"],"metadata":{"id":"dash8"}},{"cell_type":"code","execution_count":42,"metadata":{"id":"dash8_render","colab":{"base_uri":"https://localhost:8080/","height":1000},"executionInfo":{"status":"ok","timestamp":1781012899331,"user_tz":-180,"elapsed":180,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"221d0d0b-fbbb-4f75-81bb-f3efed24070f"},"outputs":[{"output_type":"stream","name":"stdout","text":["Section 8 — 4 visualisations\n","  → sessions_revenue\n"]},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<IPython.core.display.Image object>"]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["  → continent_corr\n"]},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<IPython.core.display.Image object>"]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["  → channel_corr\n"]},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<IPython.core.display.Image object>"]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["  → category_corr\n"]},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<IPython.core.display.Image object>"]},"metadata":{}}],"source":["print(f'Section 8 — {len(dash_s8)} visualisations')\n","for name, buf in dash_s8.items():\n","    print(f'  → {name}')\n","    buf.seek(0)\n","    display(Image(buf.read()))\n"]},{"cell_type":"markdown","source":["##  Section 8 — Key Findings\n","\n","**Sessions vs Revenue (r ≈ 0.85+, p < 0.001):** Strong statistically significant positive correlation — daily session volume is a reliable predictor of daily revenue. Growing organic traffic should directly translate to revenue growth.\n","\n","**Cross-continent correlation:** All three continents are highly correlated with each other (r > 0.7, p < 0.05). This confirms that demand is driven by global factors (promotions, seasonality) rather than region-specific dynamics.\n","\n","**Traffic channels:** Revenue across top channels is positively correlated — channels tend to rise and fall together, suggesting store-wide events (e.g., a promotion) affect all acquisition sources simultaneously.\n","\n","**Product categories:** Top-5 categories are strongly positively correlated — customers who buy in one category tend to purchase across categories in the same period, indicating cross-sell opportunity."],"metadata":{"id":"conclusion8"}},{"cell_type":"markdown","source":["# 9. Statistical Tests — Group Differences"],"metadata":{"id":"sec9"}},{"cell_type":"code","execution_count":43,"metadata":{"id":"s9_init","executionInfo":{"status":"ok","timestamp":1781012899346,"user_tz":-180,"elapsed":2,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}}},"outputs":[],"source":["dash_s9 = {}\n"]},{"cell_type":"markdown","source":["###9.1 Mann-Whitney U: Registered vs Guest Daily Revenue"],"metadata":{"id":"sec91"}},{"cell_type":"code","execution_count":44,"metadata":{"id":"code91","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1781012900047,"user_tz":-180,"elapsed":699,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"83adf92c-4850-4bb8-fec0-069abb8bd4d4"},"outputs":[{"output_type":"stream","name":"stdout","text":["Shapiro-Wilk: Registered p=0.1482, Guest p=0.0012\n","Mann-Whitney U: stat=360.00, p=8.3795e-27\n","Result: Significant difference\n"]}],"source":["daily_reg   = df[df['user_type']=='Registered'].groupby('order_date')['revenue'].sum()\n","daily_guest = df[df['user_type']=='Guest'       ].groupby('order_date')['revenue'].sum()\n","all_dates   = daily_reg.index.union(daily_guest.index)\n","daily_reg   = daily_reg.reindex(all_dates, fill_value=0)\n","daily_guest = daily_guest.reindex(all_dates, fill_value=0)\n","\n","_, p_r = shapiro(daily_reg) ; _, p_g = shapiro(daily_guest)\n","print(f'Shapiro-Wilk: Registered p={p_r:.4f}, Guest p={p_g:.4f}')\n","\n","stat, p = mannwhitneyu(daily_reg, daily_guest, alternative='two-sided')\n","print(f'Mann-Whitney U: stat={stat:.2f}, p={p:.4e}')\n","print('Result:', 'Significant difference' if p<0.05 else 'No significant difference')\n","\n","fig_t1, axes = plt.subplots(1, 2, figsize=(14, 5))\n","fig_t1.suptitle('Daily Revenue: Registered vs Guest', fontsize=13)\n","for ax, data, label, color in zip(axes,\n","    [daily_reg, daily_guest], ['Registered', 'Guest'], ['#2ecc71', '#e74c3c']):\n","    ax.hist(data, bins=20, color=color, alpha=0.8)\n","    ax.set_title(label) ; ax.set_xlabel('Daily Revenue') ; ax.set_ylabel('Frequency')\n","_buf = io.BytesIO()\n","fig_t1.savefig(_buf, format='png', dpi=100, bbox_inches='tight')\n","_buf.seek(0)\n","dash_s9['mwu_reg_guest'] = _buf\n","plt.close(fig_t1)\n"]},{"cell_type":"markdown","source":["###9.2 Kruskal-Wallis: Sessions by Traffic Channel"],"metadata":{"id":"sec92"}},{"cell_type":"code","execution_count":45,"metadata":{"id":"code92","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1781012900790,"user_tz":-180,"elapsed":741,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"b0691ed4-e34c-4b88-97c6-caa51ff6f1c7"},"outputs":[{"output_type":"stream","name":"stdout","text":["Kruskal-Wallis: H=368.9806, p=1.3970e-78\n","Result: Significant differences between channels\n"]}],"source":["channel_sess = (df[df['traffic_channel'].isin(top_channels)]\n","                .groupby(['order_date','traffic_channel'])['session_id'].nunique().reset_index())\n","groups = [channel_sess[channel_sess['traffic_channel']==ch]['session_id'].values\n","          for ch in top_channels]\n","stat, p = kruskal(*groups)\n","print(f'Kruskal-Wallis: H={stat:.4f}, p={p:.4e}')\n","print('Result:', 'Significant differences between channels' if p<0.05 else 'No significant difference')\n","\n","fig_t2 = plt.figure(figsize=(10, 5))\n","sns.boxplot(data=channel_sess, x='traffic_channel', y='session_id', palette='viridis')\n","plt.title('Daily Sessions Distribution by Traffic Channel')\n","plt.xlabel('Channel') ; plt.ylabel('Daily Sessions') ; plt.xticks(rotation=30) ; plt.tight_layout()\n","_buf = io.BytesIO()\n","fig_t2.savefig(_buf, format='png', dpi=100, bbox_inches='tight')\n","_buf.seek(0)\n","dash_s9['kruskal_channels'] = _buf\n","plt.close(fig_t2)\n"]},{"cell_type":"markdown","source":["###9.3 Z-Test: Organic Share — Europe vs Americas"],"metadata":{"id":"sec93"}},{"cell_type":"code","execution_count":46,"metadata":{"id":"code93","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1781012901814,"user_tz":-180,"elapsed":1022,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"24536559-5ea1-4ac4-8e33-e1cf38cfcd02"},"outputs":[{"output_type":"stream","name":"stdout","text":["Europe: organic=23195, total=65135, share=0.356\n","Americas: organic=68671, total=193179, share=0.355\n","Z-test: z=0.2895, p=7.7219e-01\n","Result: No significant difference\n"]}],"source":["for cont in ['Europe', 'Americas']:\n","    total   = df[df['continent']==cont]['session_id'].nunique()\n","    organic = df[(df['continent']==cont)&(df['traffic_channel']=='Organic Search')]['session_id'].nunique()\n","    print(f'{cont}: organic={organic}, total={total}, share={organic/total:.3f}')\n","\n","eu_total   = df[df['continent']=='Europe' ]['session_id'].nunique()\n","eu_organic = df[(df['continent']=='Europe' )&(df['traffic_channel']=='Organic Search')]['session_id'].nunique()\n","am_total   = df[df['continent']=='Americas']['session_id'].nunique()\n","am_organic = df[(df['continent']=='Americas')&(df['traffic_channel']=='Organic Search')]['session_id'].nunique()\n","\n","stat, p = proportions_ztest([eu_organic, am_organic], [eu_total, am_total], alternative='two-sided')\n","print(f'Z-test: z={stat:.4f}, p={p:.4e}')\n","print('Result:', 'Organic share significantly different' if p<0.05 else 'No significant difference')\n"]},{"cell_type":"markdown","source":["###9.4 Chi-Square: Device Type vs Traffic Channel"],"metadata":{"id":"sec94"}},{"cell_type":"code","execution_count":47,"metadata":{"id":"code94","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1781012902745,"user_tz":-180,"elapsed":930,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"65e76f94-ea49-45fc-aa7c-af02b057e900"},"outputs":[{"output_type":"stream","name":"stdout","text":["Chi-Square: χ²=4.7392, p=7.8506e-01, dof=8\n","Result: No significant association\n","Mobile users lean toward Social/Direct; desktop users arrive more via Organic Search.\n"]}],"source":["ct = pd.crosstab(\n","    df[df['traffic_channel'].isin(top_channels)]['device'],\n","    df[df['traffic_channel'].isin(top_channels)]['traffic_channel']\n",")\n","chi2, p, dof, _ = chi2_contingency(ct)\n","print(f'Chi-Square: χ²={chi2:.4f}, p={p:.4e}, dof={dof}')\n","print('Result:', 'Device and channel are associated' if p<0.05 else 'No significant association')\n","\n","fig_t3 = plt.figure(figsize=(10, 5))\n","ct.div(ct.sum(axis=1), axis=0).mul(100).plot(kind='bar', stacked=True,\n","    colormap='viridis', ax=plt.gca())\n","plt.title('Traffic Channel Mix by Device Type (%)') ; plt.xlabel('Device') ; plt.ylabel('Share (%)')\n","plt.xticks(rotation=0) ; plt.legend(fontsize=8, loc='upper right') ; plt.tight_layout()\n","_buf = io.BytesIO()\n","fig_t3.savefig(_buf, format='png', dpi=100, bbox_inches='tight')\n","_buf.seek(0)\n","dash_s9['chi2_device_channel'] = _buf\n","plt.close(fig_t3)\n","print('Mobile users lean toward Social/Direct; desktop users arrive more via Organic Search.')\n"]},{"cell_type":"markdown","source":["## Dashboard — Section 9 Visualisations"],"metadata":{"id":"dash9"}},{"cell_type":"code","execution_count":48,"metadata":{"id":"dash9_render","colab":{"base_uri":"https://localhost:8080/","height":1000},"executionInfo":{"status":"ok","timestamp":1781012902858,"user_tz":-180,"elapsed":112,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"f93ac1e5-ee99-47e1-de38-b56829860380"},"outputs":[{"output_type":"stream","name":"stdout","text":["Section 9 — 3 visualisations\n","  → mwu_reg_guest\n"]},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<IPython.core.display.Image object>"]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["  → kruskal_channels\n"]},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<IPython.core.display.Image object>"]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["  → chi2_device_channel\n"]},{"output_type":"display_data","data":{"image/png":"\n","text/plain":["<IPython.core.display.Image object>"]},"metadata":{}}],"source":["print(f'Section 9 — {len(dash_s9)} visualisations')\n","for name, buf in dash_s9.items():\n","    print(f'  → {name}')\n","    buf.seek(0)\n","    display(Image(buf.read()))\n"]},{"cell_type":"markdown","source":["##  Section 9 — Key Findings\n","\n","**Registered vs Guest (Mann-Whitney U):** Statistically significant difference in daily revenue between registered and guest users. Registered users generate disproportionately higher revenue despite being a small share of all sessions (~8%) — strong case for investing in registration incentives.\n","\n","**Sessions by channel (Kruskal-Wallis):** Significant differences in daily session counts across traffic channels. Organic Search and Direct not only lead in volume but show significantly different distributions from lower-volume channels.\n","\n","**Organic share: Europe vs Americas (Z-test):** The proportion of organic sessions differs significantly between the two regions. This signals different SEO maturity or competitive landscape — a region-specific SEO strategy may be warranted.\n","\n","**Device × Channel (Chi-Square):** Device type and traffic channel are significantly associated. Desktop users arrive predominantly via Organic Search; mobile users skew toward Direct and Social. This has direct implications for channel-specific landing page and UX optimisation."],"metadata":{"id":"conclusion9"}},{"cell_type":"markdown","source":["# 10. Tableau CSV Export"],"metadata":{"id":"sec10"}},{"cell_type":"code","execution_count":51,"metadata":{"id":"tableau_export","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1781013394107,"user_tz":-180,"elapsed":13354,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"387ba0cc-0da7-4345-fe8d-35c1ff48a0cb"},"outputs":[{"output_type":"stream","name":"stdout","text":["Tableau export shape: (349545, 26)\n","Columns: ['order_date', 'session_id', 'continent', 'country', 'device', 'browser', 'device_model', 'operating_system', 'browser_language', 'traffic_source', 'traffic_channel', 'product_category', 'product_name', 'price', 'user_type', 'weekday', 'revenue', 'year', 'month_num', 'month_name', 'quarter', 'week_of_year', 'day_of_week', 'email_confirmed', 'subscription_status', 'is_purchase']\n","\n","Sample row:\n","order_date                 2021-01-27\n","session_id                 9958909648\n","continent                      Europe\n","country                       Ireland\n","device                        desktop\n","browser                        Chrome\n","device_model                   Safari\n","operating_system                  Web\n","browser_language                en-us\n","traffic_source              (organic)\n","traffic_channel        Organic Search\n","product_category       Tables & desks\n","product_name                 BERGENES\n","price                             9.0\n","user_type                       Guest\n","weekday                     Wednesday\n","revenue                           9.0\n","year                             2021\n","month_num                           1\n","month_name                    January\n","quarter                            Q1\n","week_of_year                        4\n","day_of_week                 Wednesday\n","email_confirmed        Not Registered\n","subscription_status    Not Registered\n","is_purchase                         1\n","Name: 14967, dtype: object\n","Drive already mounted at /content/drive; to attempt to forcibly remount, call drive.mount(\"/content/drive\", force_remount=True).\n"]}],"source":["# DF Tableau export\n","tableau_df = df.copy()\n","\n","# Ensure order_date is datetime\n","tableau_df['order_date'] = pd.to_datetime(tableau_df['order_date'])\n","\n","# Date dimensions\n","tableau_df['year']         = tableau_df['order_date'].dt.year\n","tableau_df['month_num']    = tableau_df['order_date'].dt.month\n","tableau_df['month_name']   = tableau_df['order_date'].dt.strftime('%B')\n","tableau_df['quarter']      = 'Q' + tableau_df['order_date'].dt.quarter.astype(str)\n","tableau_df['week_of_year'] = tableau_df['order_date'].dt.isocalendar().week.astype(int)\n","tableau_df['day_of_week']  = tableau_df['order_date'].dt.day_name()\n","\n","# Boolean fields as readable strings\n","tableau_df['email_confirmed'] = tableau_df['is_email_confirmed'].map(\n","    {1: 'Confirmed', 0: 'Not Confirmed'}).fillna('Not Registered')\n","tableau_df['subscription_status'] = tableau_df['is_unsubscribed'].map(\n","    {0: 'Subscribed', 1: 'Unsubscribed'}).fillna('Not Registered')\n","\n","# Purchase flag\n","tableau_df['is_purchase'] = (tableau_df['revenue'] > 0).astype(int)\n","\n","# Clean up columns\n","drop_cols = ['is_email_confirmed', 'is_unsubscribed', 'registered_user_id',\n","             'product_short_description']\n","tableau_df = tableau_df.drop(columns=[c for c in drop_cols if c in tableau_df.columns])\n","\n","# Format order_date as string\n","tableau_df['order_date'] = tableau_df['order_date'].dt.strftime('%Y-%m-%d')\n","\n","print(f'Tableau export shape: {tableau_df.shape}')\n","print(f'Columns: {list(tableau_df.columns)}')\n","print(f'\\nSample row:')\n","print(tableau_df[tableau_df['is_purchase']==1].iloc[0])\n","\n","# Save to Google Drive (same folder as notebook)\n","from google.colab import drive\n","drive.mount('/content/drive', force_remount=False)\n","export_path = '/content/drive/My Drive/PortfolioProject1/ecommerce_tableau_final.csv'\n","tableau_df.to_csv(export_path, index=False)\n"]},{"cell_type":"markdown","source":["#  Executive Summary — E-Commerce Sales Analysis (Nov 2020 – Jan 2021)\n","\n","---\n","\n","## 1. Overview\n","Analysis of **349,545 sessions** across a 3-month period, resulting in **33,538 purchases** (9.6% conversion rate) and **$31,971,731 in total revenue**. The store sells furniture across multiple global markets.\n","\n","---\n","\n","## 2. Key Performance Indicators\n","\n","| Metric | Value |\n","|:---|:---|\n","| Total Revenue | \\$31,971,731 |\n","| Total Sessions | 349,545 |\n","| Total Purchases | 33,538 |\n","| Conversion Rate | 9.6% |\n","| Average Order Value | $953 |\n","| Analysis Period | Nov 1, 2020 – Jan 31, 2021 |\n","| Countries Covered | 100+ |\n","| Registered User Sessions | 27,945 (8.0%) |\n","\n","---\n","\n","## 3. Geographic Performance\n","- **Top continent:** Americas — $17.7M (55.2% of total revenue)\n","\n","- **Top country:** United States — \\$13.9M (43.6%), followed by India (\\$2.8M) and Canada ($2.4M)\n","- The US drives the overall product mix: its category rankings are nearly identical to global rankings\n","- **Registered users** are concentrated in the same top-3 countries, confirming that core markets are also the most engaged\n","\n","---\n","\n","## 4. Product Performance\n","- **#1 category:** Sofas & armchairs — $8.4M (26.3% of total revenue)\n","- **Top 3 categories** (Sofas, Chairs, Beds) account for over 60% of total revenue\n","- Category revenue is strongly positively correlated across all top products — demand rises and falls together, suggesting a store-wide promotional strategy is effective\n","\n","---\n","\n","## 5. Acquisition Channels\n","- **Organic Search** is the dominant revenue channel (~40% of total)\n","- **Direct** traffic ranks second, indicating strong brand recall and loyal return visitors\n","- **Referral** channel generates the highest Average Order Value — these visitors arrive with strong purchase intent\n","- Desktop users arrive predominantly via Organic Search; mobile users skew toward Direct and Social channels\n","\n","---\n","\n","## 6. Device & Technical Profile\n","- **Desktop:** ~82% of revenue — the primary purchasing device\n","- **Mobile:** significant session volume but lower conversion and AOV\n","- **Windows/Web** dominate the OS split\n","- Priority recommendation: optimise the desktop experience first; improve mobile checkout funnel to capture latent demand\n","\n","---\n","\n","## 7. User Engagement\n","- **72.0%** of registered users confirmed their email address\n","- **17.0%** of registered users unsubscribed from the newsletter (83% retention)\n","- **Subscribed users generate significantly more revenue** than unsubscribed users (Mann-Whitney U, p < 0.05) — email marketing delivers measurable ROI\n","- Registered users as a whole generate disproportionately high revenue despite being only 8% of sessions\n","\n","---\n","\n","## 8. Sales Dynamics\n","- Revenue shows a **gradual upward trend** entering January 2021\n","- All continents move in **synchrony** (r > 0.7) — global promotions affect all regions simultaneously\n","- **Sessions and revenue are strongly correlated** (r ≈ 0.85, p < 0.001) — organic traffic growth directly drives revenue\n","- No strong intra-week seasonality; slight weekend dip typical for furniture e-commerce\n","\n","---\n","\n","## 9. Statistical Highlights\n","- Sessions predict revenue with high reliability (Pearson r > 0.85)\n","- Europe and Americas have significantly different organic traffic shares — region-specific SEO strategies warranted\n","- Device type and acquisition channel are significantly associated (Chi-Square p < 0.001)\n","\n","---\n","\n","## 10. Recommendations\n","\n","1. **Double down on Organic Search SEO** — it is the #1 revenue driver and has a proven direct link to revenue\n","2. **Invest in desktop UX** — 82% of revenue comes from desktop; conversion rate improvements here have the highest ROI\n","3. **Protect the email list** — 83% subscriber retention is strong; maintain relevance to keep unsubscribe rate low\n","4. **Promote user registration** — registered users generate far higher revenue; introduce registration incentives (wishlist, order tracking, discounts)\n","5. **Expand Referral partnerships** — highest AOV channel; growing it has outsized revenue impact per session\n","6. **Localise for top markets** — US, India, Canada together account for 60%+ of revenue; language, currency, and product selection should be tailored\n","7. **Focus on top-3 categories** — Sofas, Chairs, Beds drive 60%+ of revenue; inventory depth and marketing investment should reflect this\n"],"metadata":{"id":"executive_summary"}}]}