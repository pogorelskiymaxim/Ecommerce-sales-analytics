{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[{"file_id":"1tcGJNMmw45BgAp-JALZMD0P6YEXtc6Bx","timestamp":1781012362461}]},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"markdown","source":["# 1. Join to DB and Libraries import"],"metadata":{"id":"ub79E6deTXnk"}},{"cell_type":"code","execution_count":1,"metadata":{"id":"5FY96K6mvjQv","executionInfo":{"status":"ok","timestamp":1781012882106,"user_tz":-180,"elapsed":20986,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}}},"outputs":[],"source":["from google.colab import auth\n","auth.authenticate_user()\n","from google.cloud import bigquery\n","import pandas as pd\n","project_id = 'data-analytics-mate'\n","client = bigquery.Client(project=project_id)\n","import numpy as np\n","import matplotlib.pyplot as plt\n","import seaborn as sns\n","import warnings\n","warnings.filterwarnings(\"ignore\", category=FutureWarning)\n","from scipy import stats\n","from scipy.stats import mannwhitneyu, kruskal, chi2_contingency, shapiro\n","from statsmodels.stats.proportion import proportions_ztest\n","from itertools import combinations\n","import io\n","from IPython.display import display, Image\n"]},{"cell_type":"markdown","source":["# 2. Create DF"],"metadata":{"id":"UGIRYMJqTiLu"}},{"cell_type":"code","source":["# SQL query\n","query = f\"\"\"\n","SELECT\n","    s.date AS order_date,\n","    s.ga_session_id AS session_id,\n","    sp.continent,\n","    sp.country,\n","    sp.device,\n","    sp.browser,\n","    sp.mobile_model_name AS device_model,\n","    sp.operating_system,\n","    sp.language AS browser_language,\n","    sp.name AS traffic_source,\n","    sp.channel AS traffic_channel,\n","    acc.id AS registered_user_id,\n","    acc.is_verified AS is_email_confirmed,\n","    acc.is_unsubscribed,\n","    p.category AS product_category,\n","    p.name AS product_name,\n","    p.price,\n","    p.short_description AS product_short_description\n","\n","FROM `{project_id}.DA.session` AS s\n","-- Joining technical session parameters\n","LEFT JOIN `{project_id}.DA.session_params` AS sp\n","    ON s.ga_session_id = sp.ga_session_id\n","-- Linking session to account via bridge table account_session\n","LEFT JOIN `{project_id}.DA.account_session` AS as_link\n","    ON s.ga_session_id = as_link.ga_session_id\n","-- Joining user account details\n","LEFT JOIN `{project_id}.DA.account` AS acc\n","    ON as_link.account_id = acc.id\n","-- Joining order information to see purchases within sessions\n","LEFT JOIN `{project_id}.DA.order` AS o\n","    ON s.ga_session_id = o.ga_session_id\n","-- Joining product catalog details\n","LEFT JOIN `{project_id}.DA.product` AS p\n","    ON o.item_id = p.item_id\n","\n","ORDER BY order_date DESC\n","\"\"\"\n","\n","# Executing the query and converting results to a Pandas DataFrame\n","df = client.query(query).to_dataframe()\n","\n","# Displaying basic info about the dataset\n","print(f\"Shape: {df.shape}\")\n","df.head()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":296},"id":"o1TpxFnF06eR","executionInfo":{"status":"ok","timestamp":1781012885699,"user_tz":-180,"elapsed":3589,"user":{"displayName":"Maksym Pohorelskyi","userId":"00512910005554450923"}},"outputId":"3a002e3a-958e-44b5-a842-21b185c19cde"},"execution_count":2,"outputs":[{"output_type":"stream","name":"stdout","text":["Shape: (349545, 18)\n"]},{"output_type":"execute_result","data":{"text/plain":["   order_date  session_id continent        country   device  browser  \\\n","0  2021-01-31   270887945  Americas  United States  desktop   Chrome   \n","1  2021-01-31  4958826563      Asia          India   mobile   Safari   \n","2  2021-01-31  6336117447  Americas  United States  desktop   Chrome   \n","3  2021-01-31   464560636  Americas  United States  desktop     Edge   \n","4  2021-01-31  5756982967    Europe        Ukraine  desktop  Firefox   \n","\n","  device_model opera